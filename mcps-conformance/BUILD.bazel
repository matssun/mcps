# MCPS-012: stdio harness — launches the mcps_stdio_server child process and
# drives the full outcome matrix over real stdin/stdout, asserting identical
# Core outcomes to the in-process object target. The server binary is delivered
# via runfiles; its path is passed through MCPS_STDIO_SERVER ($(rlocationpath))
# and resolved against TEST_SRCDIR in the test (no runfiles-crate dependency).
nt_rust_test(
    name = "stdio_harness_test",
    srcs = ["tests/stdio_harness_test.rs"],
    auto_cargo_toml = False,
    bazel_build_cfg = False,
    compile_data = ["//mcps-core:vectors"],
    data = [":mcps_stdio_server"],
    edition = "2021",
    env = {"MCPS_STDIO_SERVER": "$(rlocationpath :mcps_stdio_server)"},
    deps = [
        ":mcps_conformance_lib",
        "//mcps-core:mcps_core",
        "@crates_mcps//:serde_json",
