    },
    deps = [
        ":mcps_proxy",
        "//mcps-core:mcps_core",
        "//mcps-host:mcps_host",
        "@crates_mcps//:rcgen",
        "@crates_mcps//:rustls",
        "@crates_mcps//:rustls-pki-types",
        "@crates_mcps//:serde_json",
    ],
)

# ===========================================================================
# Phase 7 external backends (#4028 Redis, #4030 OCSP, #4034 PKCS#11, #4039
# Linux sandbox). A SINGLE library flavor builds all three Mac-buildable
# optional features together so the adapters are Bazel-built on every run; the
# default `:mcps_proxy` links none of them. The Linux sandbox enforcement is
# target-gated (compiled into ALL flavors on Linux via _PROXY_LINUX_SANDBOX_DEPS,
# excluded on Mac), so it needs no feature flavor.
# ===========================================================================
nt_rust_library(
    name = "mcps_proxy_ext",
    srcs = _PROXY_LIB_SRCS,
    crate_features = _PROXY_EXT_FEATURES,
    crate_name = "mcps_proxy",
    edition = "2021",
    deps = _PROXY_EXT_DEPS,
)

# Inline #[cfg(feature = ...)] unit tests for the external backends (ocsp.rs
# network-free codec/policy tests + the RFC 6960 §3.2 responder-SIGNATURE
# acceptance tests, cli.rs feature-gated flag tests, redis/pkcs11 inline tests).
# Built WITH the production external-backend features against the ext flavor so
# they actually compile + run on every `bazel test //...` (Mac included).
#
# #4063 (MCPS-088, closes #4030): the OCSP responder-SIGNATURE verifier
# (x509-parser/verify, the ring-backed algorithm-agnostic RSA+ECDSA verifier) is
# part of the `online_ocsp` module itself — `x509-parser/verify` is enabled
# unconditionally at the workspace level — so the SHIPPING `online_ocsp` build
# performs the real §3.2 trust chain. These acceptance tests (real signed Good →
# ADMIT; forged/wrong-key/unsigned → DENY) therefore exercise the SAME production
# code path the `online_ocsp` build ships, NOT a separate flavor. The in-tree
# Ed25519 signer (ed25519-dalek) only mints the signed fixtures.
nt_rust_test(
    name = "proxy_ext_unit_test",
    crate = ":mcps_proxy_ext",
    auto_cargo_toml = False,
    bazel_build_cfg = False,
    crate_features = _PROXY_EXT_FEATURES,
    edition = "2021",
    deps = _PROXY_LIB_DEPS + _PROXY_EXT_CRATES + [
        "@crates_mcps//:rcgen",
        # #4063 (MCPS-088): the in-tree Ed25519 signer used to mint a genuinely
        # signed OCSP response fixture for the admit/forge acceptance tests.
        "@crates_mcps//:ed25519-dalek",
    ],
)

# #4028: cross-node replay rejection over a SHARED Redis. Self-skips (prints +
# passes) unless MCPS_TEST_REDIS_URL is set, so it is green without a live Redis
# yet proves multi-node safety when one is provided (Mac: `brew install redis`).
nt_rust_test(
    name = "redis_replay_e2e_test",
    srcs = ["tests/redis_replay_e2e_test.rs"],
    auto_cargo_toml = False,
    bazel_build_cfg = False,
    crate_features = _PROXY_EXT_FEATURES,
    edition = "2021",
    env_inherit = [
        "MCPS_TEST_REDIS_URL",
        # CI opt-in: when set, a missing-infra SKIP HARD-FAILS instead of passing.
        "MCPS_REQUIRE_LIVE_INFRA",
    ],
    deps = [
        ":mcps_proxy_ext",
        "//mcps-core:mcps_core",
        "@crates_mcps//:serde_json",
        # MCPS-090: the live PTTL test probes PTTL on the exact key the cache
        # inserted, to confirm the bounded-window TTL (not the now=0 epoch TTL).
        "@crates_mcps//:redis",
    ],
)

