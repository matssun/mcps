# ===========================================================================
# Phase 1 OCI packaging of the PRODUCTION proxy artifact (mcps_proxy_ext).
#
# The lean `:mcps_proxy_cli` binary (src/main.rs + the default `:mcps_proxy`
# library) is unchanged. This is the SAME main.rs compiled against the
# external-backends `:mcps_proxy_ext` library flavor (the three Mac-buildable
# optional features), then cross-compiled to linux/amd64 and packaged into a
# single-arch distroless image. linux/amd64 ONLY for v1 (no arm64, no
# oci_image_index).
# ===========================================================================

# The production binary: same src/main.rs the lean CLI uses, but linked against
# the ext library flavor and built with the external-backend features (mirrors
# `:mcps_proxy_cli`, swapping `:mcps_proxy` -> `:mcps_proxy_ext` and adding the
# ext features).
nt_rust_binary(
    name = "mcps_proxy_ext_bin",
    srcs = ["src/main.rs"],
    crate_features = _PROXY_EXT_FEATURES,
    edition = "2021",
    # _PROXY_EXT_DEPS already includes //mcps-policy:mcps_policy (via
    # _PROXY_LIB_DEPS), so it is NOT relisted here — the lean CLI lists it
    # explicitly only because its lean dep set (`:mcps_proxy`) does not.
    deps = [":mcps_proxy_ext"] + _PROXY_EXT_DEPS,
)

# Cross-compile the ext binary to the linux/amd64 image platform (from darwin).
platform_transition_filegroup(
    name = "mcps_proxy_ext_linux_x86_64",
    srcs = [":mcps_proxy_ext_bin"],
    target_platform = "//platforms:linux_x86_64",
)

# Package the cross-compiled binary (+ its runfiles) under /app in the image.
pkg_tar(
    name = "mcps_proxy_ext_layer_x86_64",
    srcs = [":mcps_proxy_ext_linux_x86_64"],
    include_runfiles = True,
    package_dir = "/app",
)

# The single-arch linux/amd64 distroless image.
oci_image(
    name = "mcps_proxy_ext_image",
    # Single-arch: reference the platform-specific base repo directly (the
    # multi-platform `@distroless_cc_base` alias only resolves under a matching
    # incoming platform transition; this image is unconditionally linux/amd64).
    base = "@distroless_cc_base_linux_amd64",
    entrypoint = ["/app/mcps_proxy_ext_bin"],
    tars = [":mcps_proxy_ext_layer_x86_64"],
    workdir = "/app",
)

# Load the image into the local Docker daemon for verification.
oci_load(
    name = "mcps_proxy_ext_load",
    image = ":mcps_proxy_ext_image",
    repo_tags = ["mcps-proxy-ext:latest"],
)

# Push to the container registry. Defined only — DO NOT run without creds.
oci_push(
    name = "mcps_proxy_ext_push",
    image = ":mcps_proxy_ext_image",
    remote_tags = ["latest"],
    repository = "ghcr.io/matssun/code/mcps-proxy-ext",
)
