# Rust (PyO3 crate builds into a local target/ — the root .gitignore only
# anchors /target/ at the repo root, so ignore this one explicitly)
/target/

# Python build / extension artifacts
*.so
*.pyd
*.egg-info/
/dist/
/build/
__pycache__/
.pytest_cache/

# Local virtualenvs
.venv*/

# uv lockfile (auto-generated by the maturin import hook; not our chosen workflow)
uv.lock
